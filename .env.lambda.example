# Lambda（お誕生日クーポン自動発行）デプロイ用の環境変数サンプル
#
# 使い方:
#   cp .env.lambda.example .env.lambda
#   # .env.lambda を編集して値を埋める
#   source .env.lambda
#   make deploy-lambda            # コード更新 + 環境変数反映
#   # 初回のみ: make deploy-birthday-coupon
#
# .env.lambda は .gitignore で除外されます（コミット禁止）

## ─────────────────────────────────────────────
## 必須: サーバーAPI 呼び出し用
## ─────────────────────────────────────────────

# Connect-RPC エンドポイント（BulkIssueBirthdayCoupon）
export CRON_ACCESS_ENDPOINT="https://your-server.example.com/server.cron.CronCouponController/BulkIssueBirthdayCoupon"

# Authorization ヘッダに乗せる秘密トークン
export CRON_ACCESS_SECRET=""

# X-Cron-Key ヘッダに乗せる鍵
export CRON_ACCESS_KEY=""

## ─────────────────────────────────────────────
## 任意: メール通知（運用者向け）
## 1つでも未設定の場合はメール通知はスキップされ、Discord 通知のみ稼働します
## サーバー本体 (.env の MAIL_*) と同じ SMTP 認証情報を再利用するのを推奨
## ─────────────────────────────────────────────

export MAIL_HOST=""
export MAIL_PORT="587"                                              # 465 を指定すると暗黙のTLS
export MAIL_USER=""
export MAIL_PASS=""
export MAIL_FROM="no-reply@heiwadai-hotel.app"

# 通知先メールアドレス（カンマ区切りで複数指定可）
# 例: "ops@heiwadai-hotel.app,hirakawa@example.com"
export OPERATOR_MAIL_TO=""

## ─────────────────────────────────────────────
## 任意: AWS / Lambda 設定（デフォルトを変える場合のみコメント解除）
## ─────────────────────────────────────────────

# export AWS_REGION="ap-northeast-1"
# export AWS_PROFILE="heiwadai"
# export LAMBDA_FUNCTION_NAME="heiwadai-birthday-coupon-issuer"
